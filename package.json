{
  "name": "ai-model-router",
  "version": "1.0.6",
  "description": "Terminal router for Claude, Codex, Gemini, and local HTTP-hosted LLMs with token tracking and automatic model handoff",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "https://github.com/pAbhishek24/athena-ai-router.git"
  },
  "main": "src/cli.js",
  "bin": {
    "model-router": "bin/model-router.js"
  },
  "files": [
    "bin/",
    "config/router.config.example.json",
    "README.md",
    "LICENSE",
    "src/"
  ],
  "scripts": {
    "start": "node bin/model-router.js",
    "dev": "node bin/model-router.js",
    "test": "node --test",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "ai",
    "cli",
    "claude",
    "codex",
